#include "raylib.h"

int main()
{
    Texture2D sprite;  
    Texture2D sprite2;

    InitWindow(800, 450, "basic window");
   

    sprite = LoadTexture("feliz.png"); 
    sprite2 = LoadTexture("inimigo.png");   

    
    while (!WindowShouldClose())
    {
        BeginDrawing();

        ClearBackground(RAYWHITE);

        DrawTexture(sprite, 25, 50, WHITE);
        DrawTexture(sprite2, 50, 25, WHITE);

        EndDrawing();
    }

    CloseWindow();

    return 0;
}
